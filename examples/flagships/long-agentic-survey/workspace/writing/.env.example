# Copy to .env, fill only the capabilities you choose, and keep .env private.
# Shell environment variables take precedence over these values.

# Recommended for the deep multi-provider research profile
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Optional: authenticated GitHub repository discovery (keyless requests are rate-limited)
GITHUB_TOKEN=

# Optional: only for hybrid OpenAI embeddings or direct API-worker stages
OPENAI_API_KEY=
# MALACLAW_OPENAI_API_KEY=

# Optional: only for the corresponding direct API runtime or approved image feature
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# LONGWRITE_NANOBANANA_API_KEY=

# Optional local-tool overrides
